{
	"name": "proxystudio.app",
	"version": "0.0.0",
	"author": "MarioMH <dev@mariomh.com>",
	"description": "A website that creates custom TCG cards",
	"keywords": [
		"tcg",
		"card creator",
		"card game",
		"custom cards",
		"react",
		"tailwind"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MarioMH8/proxystudio.app.git",
		"directory": "app"
	},
	"homepage": "https://proxystudio.app",
	"bugs": {
		"url": "https://github.com/MarioMH8/proxystudio.app/issues"
	},
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"commitlint": "commitlint --edit",
		"dev": "vite",
		"generate:thumbs": "bun scripts/generate-thumbs.ts",
		"lint": "eslint --cache .",
		"lint:ci": "eslint --cache --cache-strategy content .",
		"lint:fix": "eslint --cache --fix .",
		"prepare": "husky",
		"preview": "vite preview",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@fontsource-variable/inter": "5.2.8",
		"cmdk": "1.1.1",
		"cva": "1.0.0-beta.4",
		"lucide-react": "1.8.0",
		"radix-ui": "1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-resizable-panels": "4.10.0",
		"react-router": "7.13.2",
		"sonner": "2.0.7",
		"tailwind-merge": "3.5.0"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@hexadrop/eslint-config": "0.1.19",
		"@hexadrop/tsconfig": "0.0.5",
		"@tailwindcss/vite": "4.2.2",
		"@types/bun": "1.3.11",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/sharp": "0.32.0",
		"@vite-pwa/assets-generator": "1.0.2",
		"@vitejs/plugin-react": "6.0.1",
		"eslint": "9.39.4",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"sharp": "0.34.5",
		"sharp-ico": "0.1.5",
		"tailwindcss": "4.2.2",
		"tailwindcss-flow-type": "0.0.2",
		"typescript": "5.9.3",
		"vite": "8.0.8",
		"vite-plugin-pwa": "1.2.0"
	}
}
